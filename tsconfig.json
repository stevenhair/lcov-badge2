{
  "extends": [
    "@tsconfig/node18",
    "@tsconfig/strictest"
  ],
  "compilerOptions": {
    "module": "nodenext",
    "removeComments": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "declaration": true,
    "types": ["node", "jest"]
  },
  "include": [
    "src/**/*.ts"
  ]
}
